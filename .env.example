# MCP Tools API Keys

# ref.tools MCP Server — library documentation
# Get your key at: https://ref.tools
# Used in opencode.json (ref MCP) — insert your key in the URL or set this variable
REF_API_KEY=your_api_key_here

# GitHub MCP Server
# Generate a token at: https://github.com/settings/tokens (requires scopes: repo)
# Used by: github MCP (Claude Code .mcp.json + OpenCode opencode.json)
GITHUB_PERSONAL_ACCESS_TOKEN=your_github_token_here

# OpenCode — experimental LSP tool
# Required for agents to use go-to-definition, find-references, etc.
OPENCODE_EXPERIMENTAL_LSP_TOOL=true
