# MCP Tools API Keys

# ref.tools MCP Server — dokumentacja bibliotek
# Zdobądź klucz na stronie: https://ref.tools
# Używany w opencode.json (ref MCP) — wstaw swój klucz w URL lub ustaw tę zmienną
REF_API_KEY=your_api_key_here

# GitHub MCP Server
# Wygeneruj klucz na stronie: https://github.com/settings/tokens (potrzebuje scopes: repo)
# Używany przez: github MCP (Claude Code .mcp.json + OpenCode opencode.json)
GITHUB_PERSONAL_ACCESS_TOKEN=your_github_token_here

# OpenCode — experimental LSP tool
# Wymagane żeby agenci mogli używać go-to-definition, find-references itp.
OPENCODE_EXPERIMENTAL_LSP_TOOL=true
